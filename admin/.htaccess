# ══════════════════════════════════════════════════════════════════════════════
# admin/.htaccess — Protections de l'espace administration
# ══════════════════════════════════════════════════════════════════════════════

# ── Fichiers internes (jamais servis directement) ─────────────────────────────
# config.php et db.php sont des includes — aucune raison d'y accéder via HTTP.
<FilesMatch "^(config|db)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── setup.php : localhost uniquement ──────────────────────────────────────────
# Accessible en local (WAMP) mais bloqué depuis internet.
# → En production sur OVH : supprimez ce fichier après la première configuration.
<Files "setup.php">
    Order deny,allow
    Deny from all
    Allow from 127.0.0.1
    Allow from ::1
    Allow from localhost
</Files>

# ── Fichiers de suppression / bascule : POST uniquement ───────────────────────
# Ces scripts ne doivent jamais répondre à un GET direct sans CSRF.
# (La protection CSRF PHP est déjà en place ; cette règle est un filet supplémentaire.)
<FilesMatch "^(delete|toggle|user-delete)\.php$">
    <LimitExcept GET POST>
        Order allow,deny
        Deny from all
    </LimitExcept>
</FilesMatch>

# ── Pas de listing des fichiers admin ─────────────────────────────────────────
Options -Indexes
